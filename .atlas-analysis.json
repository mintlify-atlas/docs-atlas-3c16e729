  "keyFeatures": [
    "Role-based access control with five distinct roles: Administrator, Coordinator, Evaluator, Speaker, and Participant",
    "End-to-end event lifecycle management (Draft → Published → Closed)",
    "Evaluation rubrics with criteria scoring and conflict-free evaluator assignment",
    "Speaker submission workflow with document validation states (CV, biography, slides)",
    "Participant project registration with QR access passes and certificate generation",
    "Event schedule management with space/venue conflict detection",
    "Audit logging for all authentication and data-change events",
    "Report generation in PDF and XLSX formats",
    "Public ranking dashboard showing real-time evaluation results per event"
  ],
  "publicApiSurface": [
    "GET / — Public ranking dashboard (home.views.index)",
    "GET /ranking/data/ — JSON ranking data endpoint (home.views.ranking_data)",
    "POST /login/ — User authentication (principal.views.login_view)",
    "POST /registrar/ — New user registration (principal.views.registrar_view)",
    "POST /recuperar/ — Account recovery request (principal.views.recuperar_cuenta_view)",
    "GET/POST /set-password/<uidb64>/<token>/ — Password setup from admin invite",
    "GET /administrador/ — Administrator dashboard",
    "GET /administrador/usuarios/ — User management",
    "GET /administrador/eventos/ — Event listing",
    "GET /administrador/auditoria/ — Audit log viewer",
    "GET /coordinador/ — Coordinator dashboard",
    "GET /coordinador/gestion/ — Active event management",
    "GET /coordinador/cronograma/ — Schedule management",
    "GET /coordinador/inscripciones/ — Inscription management",
    "GET /coordinador/evaluadores/ — Evaluator assignment",
    "GET /coordinador/espacios/ — Venue/space management",
    "GET /coordinador/rubricas/ — Rubric management",
    "GET /coordinador/reportes/ — Report generation",
    "GET /evaluador/ — Evaluator dashboard",
    "GET /evaluador/proyectos/ — Assigned projects list",
    "GET /evaluador/formulario/<id>/ — Evaluation submission form",
    "GET /ponente/ — Speaker panel",
    "GET /ponente/participacion/ — Speaker participation management",
    "GET /ponente/constancia/pdf/<id>/ — Speaker certificate PDF download",
    "GET /participante/ — Participant panel",
    "GET /participante/gestion/ — Project submission and management",
    "GET /participante/pase/ — QR access pass",
    "GET /participante/constancia/pdf/ — Participation certificate PDF download"
  ]
